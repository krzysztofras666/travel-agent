OPENAI_API_KEY=sk-...

# Optional overrides
# OPENAI_MODEL=gpt-4o-mini
# TRAVEL_OPENAI_MODEL=gpt-4o-mini
# TRAVEL_HTTP_TIMEOUT=20
# TRAVEL_FETCH_CONCURRENCY=6
# TRAVEL_MAX_TEXT_CHARS=18000
# TRAVEL_MAX_OFFERS_PER_DEST=3
# TRAVEL_BROWSER_RETRY_MIN_CHARS=2000

# Email (optional — needs Gmail OAuth token from gmail-agent)
# TRAVEL_EMAIL_FROM=you@gmail.com
# TRAVEL_EMAIL_TO=you@gmail.com,friend@example.com
# GMAIL_TOKEN_DIR=~/.config/gmail-agent
